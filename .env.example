# Database
DATABASE_URL=postgresql+asyncpg://postgres:atlasdb@db:5432/atlasdb
POSTGRES_USER=postgres
POSTGRES_DB=atlasdb
POSTGRES_PASSWORD=atlasdb

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-...

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# S3 (only required when STORAGE_BACKEND=s3)
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Query engine
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MAX_CHUNKS_PER_QUERY=4
